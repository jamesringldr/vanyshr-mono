# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...

# Geoapify (zip code lookup)
VITE_GEOAPIFY_API_KEY=

# Zabasearch Relay Worker
# Base URL of the deployed Cloudflare Worker (no trailing slash).
# Deploy: cd workers/zabasearch-relay && wrangler deploy
VITE_ZABA_RELAY_URL=https://zabasearch-relay.vanyshrrelay.workers.dev
